{
  "manifest_version": 3,
  "name": "豆豆 - AI自媒体工具",
  "version": "3.0.1",
  "description": "人人都能做自媒体",
  "permissions": [
    "storage",
    "tabGroups",
    "scripting",
    "cookies",
    "debugger",
    "downloads",
    "clipboardRead",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "sidePanel",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/doudou_16.png",
      "48": "icons/doudou_48.png",
      "128": "icons/doudou_128.png"
    },
    "default_title": "doudou",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/floating-btn.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://www.douyin.com/*", "https://*.douyin.com/*"],
      "js": ["src/douyin/downloader.js"],
      "css": ["src/douyin/downloader.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/doudou_16.png",
    "48": "icons/doudou_48.png",
    "128": "icons/doudou_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "src/crawler-selector.js",
        "src/image_text/*",
        "bundles/inject.js",
        "bundles/platforms/*.js",
        "src/ai/openai.js"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "resources": [
        "src/douyin/inject.js"
      ],
      "matches": [
        "https://www.douyin.com/*",
        "https://*.douyin.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; img-src * data: blob: filesystem:;"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  }
}
